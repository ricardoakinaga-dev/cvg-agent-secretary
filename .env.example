NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# PostgreSQL
DATABASE_URL=postgres://postgres:postgres@localhost:5432/cvg_agent
DB_MAX_CONNECTIONS=10

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# AI provider
AI_PROVIDER=auto
OPENAI_API_KEY=sk-replace-me
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=500
OPENAI_TEMPERATURE=0.7

# Optional fallback provider
OPENROUTER_API_KEY=
OPENROUTER_MODEL=

# Chatwoot
CHATWOOT_API_URL=https://app.chatwoot.com
CHATWOOT_API_TOKEN=replace-me
CHATWOOT_ACCOUNT_ID=replace-me
CHATWOOT_WEBHOOK_SECRET=replace-me

# Operational API auth
API_ADMIN_TOKEN=replace-me-with-a-long-random-token

# Optional Qdrant vector store.
# In docker compose, an empty QDRANT_URL uses http://qdrant:6333.
# For local execution outside compose, use http://localhost:6333 when Qdrant is running.
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=cvg_knowledge_chunks

# Optional direct EvolutionAPI provider. The main runtime replies via Chatwoot.
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
WHATSAPP_INSTANCE=default
SEND_EVOLUTION_TEST_MESSAGE=false
TEST_WHATSAPP_NUMBER=
EVOLUTION_TEST_MESSAGE=Teste automatico EvolutionAPI -> WhatsApp.

# Staging smoke test. Use an existing Chatwoot conversation/contact in staging.
AGENT_BASE_URL=http://localhost:3000
SMOKE_CHATWOOT_CONVERSATION_ID=1
SMOKE_CHATWOOT_ACCOUNT_ID=1
SMOKE_CHATWOOT_INBOX_ID=1
SMOKE_CHATWOOT_CONTACT_ID=1
SMOKE_CHATWOOT_CONTACT_NAME=Smoke Test
SMOKE_MESSAGE_CONTENT=Teste automatico de readiness do agent-secretary.
SMOKE_STRICT_HEALTH=true
SMOKE_TIMEOUT_MS=10000
